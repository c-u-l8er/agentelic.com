/**
 * <%= agent_name %> — MCP server agent.
 *
 * Generated by Agentelic from SpecPrompt spec v<%= version %>.
 */

import { Server } from "@modelcontextprotocol/sdk/server/index.js";
import { StdioServerTransport } from "@modelcontextprotocol/sdk/server/stdio.js";

const server = new Server({
  name: "<%= agent_name |> String.downcase() |> String.replace(~r/[^a-z0-9]+/, "-") %>",
  version: "<%= version %>",
}, {
  capabilities: {
    tools: {},
  },
});

// Tool handlers generated from spec capabilities
server.setRequestHandler("tools/list", async () => ({
  tools: [
<%= for cap <- capabilities do %>    {
      name: "<%= cap.name |> String.downcase() |> String.replace(~r/[^a-z0-9]+/, "_") %>",
      description: "<%= cap.description |> String.replace("\"", "\\\"") %>",
      inputSchema: { type: "object", properties: {} },
    },
<% end %>  ],
}));

async function main() {
  const transport = new StdioServerTransport();
  await server.connect(transport);
}

main().catch(console.error);
