defmodule <%= agent_module %> do
  @moduledoc """
  <%= agent_name %> — MCP server agent.

  Generated by Agentelic from SpecPrompt spec v<%= version %>.

  Capabilities:
  <%= for cap <- capabilities do %>
  - <%= cap.name %>: <%= cap.description %>
  <% end %>

  Constraints:
  <%= for constraint <- constraints do %>
  - [<%= constraint.type %>] <%= constraint.description %>
  <% end %>
  """

  @doc "Handle an incoming agent request."
  def handle(input, context \\ %{}) do
    # Route to capability handlers based on input
    %{
      text: "",
      tool_calls: [],
      escalated: false,
      escalation_reason: nil
    }
  end
end
